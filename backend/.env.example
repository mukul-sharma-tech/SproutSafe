# ─── Required ────────────────────────────────────────────────
# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/cybernest

# Secret key used to sign JWT tokens — change this to any long random string
JWT_SECRET=cybernest_super_secret_jwt_key_change_me_in_production

# ─── Optional ────────────────────────────────────────────────
# Server port (defaults to 5000 if not set)
PORT=5000

# Node environment
NODE_ENV=development

