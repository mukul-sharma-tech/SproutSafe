# Copy this file to .env and fill in your values

VITE_BACKENDURL=http://localhost:5000

# Ollama (local AI) — run: ollama serve && ollama pull llama3
VITE_OLLAMA_URL=http://localhost:11434

# Groq (cloud AI fallback) — get key at https://console.groq.com
# Used automatically when Ollama is unavailable (e.g. cloud deployment)
VITE_GROQ_API_KEY=
