# Copy this file to .env and fill in your values

VITE_BACKENDURL=http://localhost:5000

# Auth0 — needed for Google sign-in (optional, direct login still works without it)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=

# Supabase — needed for verification flow (optional)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Gemini — needed for voice assistant (optional)
VITE_GEMINI_API_KEY=
